{% schema %}
{
  "name": "Homepage Hero Override",
  "target": "body",
  "settings": []
}
{% endschema %}

<style>
  /* Base Container Styles */
  .custom-hero-container { 
    width: 100%; 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
    display: block; 
  }
  
  /* 1. Centered Layout Styles */
  .hero-centered {
    position: relative; 
    padding: 120px 20px; 
    text-align: center; 
    color: white; 
    background-size: cover; 
    background-position: center;
  }
  .hero-centered-overlay {
    position: absolute; 
    top: 0; left: 0; right: 0; bottom: 0; 
    background: rgba(0,0,0,0.4); 
    z-index: 1;
  }
  .hero-content { 
    position: relative; 
    z-index: 2; 
    max-width: 800px; 
    margin: 0 auto; 
  }
  .hero-heading { 
    font-size: clamp(32px, 5vw, 56px); 
    font-weight: 800; 
    margin: 0 0 16px 0; 
    color: white;
    line-height: 1.2;
  }
  .hero-sub { 
    font-size: clamp(16px, 2vw, 20px); 
    margin: 0 0 32px 0; 
    color: rgba(255,255,255,0.9);
  }
  .hero-btn { 
    display: inline-block; 
    padding: 14px 32px; 
    background: white; 
    color: black; 
    text-decoration: none; 
    font-weight: 600; 
    border-radius: 4px; 
    transition: transform 0.2s;
  }
  .hero-btn:hover { transform: translateY(-2px); }

  /* 2. Split Layout Styles */
  .hero-split {
    display: flex; 
    flex-wrap: wrap; 
    color: white; 
    min-height: 500px;
  }
  .hero-split-text { 
    flex: 1; 
    min-width: 300px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    padding: 8% 5%; 
  }
  .hero-split-img { 
    flex: 1; 
    min-width: 300px; 
    background-size: cover; 
    background-position: center; 
    min-height: 400px;
  }
</style>

<script>
  (function() {
    console.log("🚀 Hero Override Script Started");

    if (window.location.pathname !== "/") {
      console.log("🛑 Not on homepage, aborting.");
      return;
    }

    var shopDomain = '{{ shop.myshopify_domain }}'; 
    var appUrl = "https://themee-xi.vercel.app"; 
    var API_URL = appUrl + "/api/faqs"; // Make sure this matches your Remix route!

    console.log("📡 Fetching custom hero data for:", shopDomain);

    fetch(API_URL + "?shop=" + shopDomain)
      .then(function(res) { 
        if (!res.ok) throw new Error("HTTP Status " + res.status);
        return res.json(); 
      })
      .then(function(data) {
        console.log("✅ Data received from backend:", data);

        if (!data || !data.heroContent) {
          console.log("🛑 Missing 'heroContent' in database, aborting.");
          return;
        }
        
        console.log("🪄 Data found! Hiding native banner and rendering custom UI.");
        
        // Hide the native Dawn banner
        var styleBlock = document.createElement('style');
        styleBlock.innerHTML = '.banner, .hero, .slideshow { display: none !important; }';
        document.head.appendChild(styleBlock);

        renderCustomHero(data.heroContent, data.heroSettings);
      })
      .catch(function(err) { 
        console.error("❌ Hero Override Fetch Error:", err); 
      });

    function renderCustomHero(content, config) {
      var main = document.querySelector('main') || document.querySelector('#MainContent');
      if (!main) return;

      var customHeroWrapper = document.createElement('div');
      customHeroWrapper.className = 'shopify-section custom-hero-container';
      customHeroWrapper.id = 'injected-hero-override';

      // (We are just doing the centered layout here for testing quickly)
      var bgImage = content.imageUrl || 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=2000&q=80';
      
      customHeroWrapper.innerHTML = '<div class="hero-centered" style="background-color: '+config.color+'; background-image: url('+bgImage+');">' +
                  '<div class="hero-centered-overlay"></div>' +
                  '<div class="hero-content">' +
                    '<h1 class="hero-heading">' + content.heading + '</h1>' +
                    '<p class="hero-sub">' + content.subheading + '</p>' +
                    '<a href="'+content.buttonUrl+'" class="hero-btn">' + content.buttonText + '</a>' +
                  '</div>' +
                '</div>';

      var nativeBanner = document.querySelector('.banner') || document.querySelector('.hero') || document.querySelector('.slideshow');
      
      if (nativeBanner) {
        var parentSection = nativeBanner.closest('.shopify-section');
        if (parentSection && parentSection.parentNode) {
          parentSection.parentNode.insertBefore(customHeroWrapper, parentSection);
        } else {
          nativeBanner.parentNode.insertBefore(customHeroWrapper, nativeBanner);
        }
      } else {
        main.prepend(customHeroWrapper);
      }
      console.log("🎉 Custom Hero injected successfully!");
    }
  })();
</script>